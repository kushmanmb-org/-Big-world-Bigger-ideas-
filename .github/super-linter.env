# Super Linter Environment Configuration
# This file customises GitHub Super Linter behaviour for the
# -Big-world-Bigger-ideas- repository.
#
# These variables are read by the super-linter/super-linter action when
# LINTER_RULES_PATH is set to .github/linters (the directory containing
# this file and per-language config files).
#
# Reference: https://github.com/super-linter/super-linter#environment-variables

# -----------------------------------------------------------------------
# General settings
# -----------------------------------------------------------------------

# Lint all files in the repo (set to true for a full audit run)
VALIDATE_ALL_CODEBASE=false

# Only report errors; do not fail the workflow for warnings
DISABLE_ERRORS=false

# -----------------------------------------------------------------------
# Language toggles
# -----------------------------------------------------------------------
VALIDATE_JAVASCRIPT_ES=true
VALIDATE_JAVASCRIPT_STANDARD=false
VALIDATE_JSON=true
VALIDATE_YAML=true
VALIDATE_MARKDOWN=true
VALIDATE_CSS=true
VALIDATE_HTML=true
VALIDATE_BASH=true

# Solidity linting handled by Foundry — disable in Super Linter
VALIDATE_SOLIDITY=false

# -----------------------------------------------------------------------
# Paths to exclude from linting
# -----------------------------------------------------------------------
FILTER_REGEX_EXCLUDE=(node_modules|dist|lib|\.min\.js|\.min\.css|package-lock\.json)

# -----------------------------------------------------------------------
# Log level (VERBOSE | DEBUG | NOTICE | WARN | ERROR)
# -----------------------------------------------------------------------
LOG_LEVEL=NOTICE
