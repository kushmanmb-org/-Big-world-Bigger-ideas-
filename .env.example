# Environment Variables Example
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# Etherscan API Key
# Get your free API key from: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Blockchair API Key (optional)
# Get your API key from: https://blockchair.com/api
BLOCKCHAIR_API_KEY=your_blockchair_api_key_here

# Private Keys (NEVER commit actual private keys!)
# Use encrypted wallet files instead when possible
# PRIVATE_KEY=your_private_key_here

# RPC URLs (optional - defaults are provided)
# ETHEREUM_RPC_URL=https://ethereum.publicnode.com
# BASE_RPC_URL=https://mainnet.base.org
# POLYGON_RPC_URL=https://polygon-rpc.com

# Withdrawal Credentials (for Ethereum staking and receiving funds)
# WITHDRAWAL_ADDRESS=your_ethereum_address_here
# ENS_NAME=your_ens_name.eth

# Global Wallet Lock – set to false to re-enable outgoing transfers.
# When unset or set to any value other than 'false', all wallet sends are blocked.
# See src/wallet.js for details.
# WALLET_GLOBAL_LOCK=false
